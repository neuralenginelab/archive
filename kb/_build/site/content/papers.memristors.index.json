{"version":3,"kind":"Article","sha256":"3f47ce8537d00f2411931f0ba855b145e3241a4d6873d5f32235e518bd8ccc69","slug":"papers.memristors.index","location":"/papers/memristors/index.md","dependencies":[],"frontmatter":{"title":"Memristors","description":"Memristor theory, circuit models, SPICE simulation, memristive systems, and the fourth circuit element.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-bf934ab4a6a84fba4e03ff014eebd06f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Scope","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"Z2B2lK1zTR"}],"identifier":"scope","label":"Scope","html_id":"scope","implicit":true,"key":"sIHcNcIPy5"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"The memristor is a two-terminal passive circuit element whose resistance is determined by its charge or current history. Postulated by Leon Chua in 1971 as the fourth fundamental circuit element alongside the resistor, capacitor, and inductor, it was physically realised in 2008 in a titanium dioxide thin-film device at HP Labs. Its defining electrical signature: a pinched hysteresis loop in the current-voltage plane that collapses to a single-valued curve at high frequency. This property is shared by a broad class of devices: collectively termed memristive systems unified by a state-variable formulation coupling voltage, current, and an internal physical variable.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"uDDqgLUszV"}],"key":"n2sUDi3Rz8"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Relevance","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"lHMUGVkR6y"}],"identifier":"relevance","label":"Relevance","html_id":"relevance","implicit":true,"key":"bZZmhd4Ddu"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Continuous, analogue conductance tuning in response to voltage pulses makes the memristor a natural physical substrate for synaptic weight storage and update. Weight modification is local and requires no separate processor, enabling in-situ implementation of STDP and other spike-driven learning rules. At the array level, memristors placed at crossbar intersections implement dense passive weight matrices capable of analogue vector-matrix multiplication the core operation of neural inference.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"EgIlEEBr8V"}],"key":"afwM4HAVR2"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Cross-references","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Brz5CM3bVb"}],"identifier":"cross-references","label":"Cross-references","html_id":"cross-references","implicit":true,"key":"YyZP2esi0q"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Memristor theory provides the conceptual framework for the device physics in ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"xyofy5s9yq"},{"type":"link","url":"/papers/rram-devices","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"RRAM Devices","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"ErZqmQVTuR"}],"urlSource":"../rram-devices/index.md","dataUrl":"/papers.rram-devices.index.json","internal":true,"protocol":"file","key":"qivQ0yMOeu"},{"type":"text","value":" and directly motivates the synaptic implementations in ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"CfFtoeWwwI"},{"type":"link","url":"/papers/neuromorphic-hw","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Neuromorphic Hardware","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"Cr4YjCJOMa"}],"urlSource":"../neuromorphic-hw/index.md","dataUrl":"/papers.neuromorphic-hw.index.json","internal":true,"protocol":"file","key":"xCAdApDdzj"},{"type":"text","value":". The plasticity rules these devices seek to implement are covered in ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"w9zrhmlVxS"},{"type":"link","url":"/papers/plasticity","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Plasticity","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"jLlHOzAQK6"}],"urlSource":"../plasticity/index.md","dataUrl":"/papers.plasticity.index.json","internal":true,"protocol":"file","key":"DgHgKn1SyK"},{"type":"text","value":".","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"cf24adThBI"}],"key":"fCW5vcki0O"},{"type":"heading","depth":2,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"Papers","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"ME57MYnPlU"}],"identifier":"papers","label":"Papers","html_id":"papers","implicit":true,"key":"Gwh7yvaLgt"},{"type":"heading","depth":3,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"2020","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"fxvWjsOLro"}],"identifier":"id-2020","label":"2020","html_id":"id-2020","implicit":true,"key":"yoECWZyF5i"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":24