{"version":3,"kind":"Article","sha256":"d32bce61e51b342d446dbee58b95ddb8849c6a556f2c0efd24142e7fd2148ba4","slug":"papers.cultures-mea.index","location":"/papers/cultures-mea/index.md","dependencies":[],"frontmatter":{"title":"Cultures & MEA","description":"Neuronal cultures, multi-electrode arrays, burst dynamics, closed-loop stimulation, and network learning in vitro.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-5aa76ee1261e00bee162d57dbfd09811.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Scope","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"pW23iBbODb"}],"identifier":"scope","label":"Scope","html_id":"scope","implicit":true,"key":"c4y2EjVSRk"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Neuronal cultures grown on multi-electrode arrays (MEAs) are a reductionist platform for network-level neural dynamics. Dissociated cortical or hippocampal neurons plated onto extracellular electrode grids allow simultaneous recording from hundreds of sites and targeted electrical stimulation. Over days to weeks in vitro, these cultures self-organise into spontaneously active networks: synchronous burst dynamics in early development, avalanche statistics consistent with criticality at maturation, and stimulus-driven connectivity changes throughout.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Na4c5mwwIU"}],"key":"CfTIzM9UpI"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Relevance","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"u0Garimj71"}],"identifier":"relevance","label":"Relevance","html_id":"relevance