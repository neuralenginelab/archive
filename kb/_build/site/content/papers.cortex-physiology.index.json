{"version":3,"kind":"Article","sha256":"daae0239ef46df3be52741241a53a54e960c30e04af51eb93058332084838d46","slug":"papers.cortex-physiology.index","location":"/papers/cortex-physiology/index.md","dependencies":[],"frontmatter":{"title":"Cortex Physiology","description":"Place cells, grid cells, mirror neurons, visual cortex, and auditory processing. How cortical circuits perform specific computational tasks.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-8c574241573048fb1e50f22a9e756c63.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Scope","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"IGzszCEWBQ"}],"identifier":"scope","label":"Scope","html_id":"scope","implicit":true,"key":"lBeDFmfOC9"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Cortical physiology examines how specific circuits in the cerebral cortex implement sensory, motor, and cognitive computations. Rather than studying networks in the abstract, this domain analyses the firing patterns, receptive fields, and circuit motifs of identified cell types in specific regions during behaviour. Methods span in vivo electrophysiology, calcium imaging, and optogenetics.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"eTGBFFV3rz"}],"key":"i0UAx6HNAS"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Relevance","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"py0NHmvXSf"}],"identifier":"relevance","label":"Relevance","html_id":"relevance","implicit":true,"key":"ESLJ7K5CL7"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"colum