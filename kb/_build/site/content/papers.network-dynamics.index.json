{"version":3,"kind":"Article","sha256":"80b3c896e12a730ccc2a02e24a2c67ca58e933d7ec1b50e94f5f38af13c71612","slug":"papers.network-dynamics.index","location":"/papers/network-dynamics/index.md","dependencies":[],"frontmatter":{"title":"Network Dynamics","description":"Neural oscillations, gamma and theta rhythms, synchrony, Hopfield networks, and cortical dynamics.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-dbe3cfd0dcb0a47811d7696746bd6c81.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Scope","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"B0ki84RidT"}],"identifier":"scope","label":"Scope","html_id":"scope","implicit":true,"key":"kgY3YD13zN"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Network dynamics concerns the collective behaviour of neurons coupled through excitatory and inhibitory synapses. Individual neurons fire spikes, but coupled populations generate oscillations, transient synchrony, attractor states, and chaotic trajectories: phenomena with no single-neuron counterpart. These emergent properties are the necessary bridge between cellular mechanisms and systems-level computation.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Df6VrrI82v"}],"key":"n1qu4zFilC"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Relevance","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"bxJtiN42eW"}],"identifier":"relevance","label":"Relevance","html_id":"relevance","implicit":true,"key":"toVqF62kW4"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"typ