{"version":3,"kind":"Article","sha256":"6dd70d038987b8406b141271afb360dd5c2d3f1525533940d3c519c7583b242a","slug":"papers.neuromorphic-hw.index","location":"/papers/neuromorphic-hw/index.md","dependencies":[],"frontmatter":{"title":"Neuromorphic Hardware","description":"Neuromorphic chips and systems — Loihi, TrueNorth, SpiNNaker, Neurogrid, analog VLSI, and silicon neurons.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-a56f3b523444fe61872d523353a5789d.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"What is this domain?","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"cPx30lVuaO"}],"identifier":"what-is-this-domain","label":"What is this domain?","html_id":"what-is-this-domain","implicit":true,"key":"aPYqvogAQC"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Neuromorphic hardware refers to electronic systems whose architecture is explicitly inspired by the structure and dynamics of biological neural circuits. Rather than executing sequential instructions on a von Neumann processor, neuromorphic chips implement networks of spiking neuron and synapse circuits directly in silicon, with computation emerging from the propagation of spike events through a reconfigurable connectivity fabric. The field traces its origins to Carver Mead’s analog VLSI work at Caltech in the late 1980s.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"RUHBpaJOr5"}],"key":"L9glhec7h3"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why it matters","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"uiln0mXJqY"}],"identifier":"why-it-matters","label":"Why it matters","html_id":"why-it-matters","implicit":true,"key":"lCophpeVbf"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Spiking neural networks processed on neuromorphic hardware offer potentially transformative advantages in energy efficiency and latency for event-driven, sparse data streams — the kind of data produced by dynamic vision sensors, audio preprocessing pipelines, and biological neural recordings. For applications where inference must run at milliwatt power budgets (edge devices, implantable BCI systems), neuromorphic approaches offer a compelling alternative to GPU-based deep learning inference.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"JBZN1bBcO6"}],"key":"epNuvPntM2"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Core concepts","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"XgPu2KL6Pc"}],"identifier":"core-concepts","label":"Core concepts","html_id":"core-concepts","implicit":true,"key":"xsIBd2Ua7Q"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Intel Loihi / Loihi 2","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"evDntYFcfP"}],"key":"FmEz7s3XrH"},{"type":"text","value":" — a research chip implementing up to 1 million neurons with on-chip STDP learning, programmable synaptic dynamics, and a hierarchical mesh interconnect","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"Hu