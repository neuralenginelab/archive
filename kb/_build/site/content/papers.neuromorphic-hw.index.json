{"version":3,"kind":"Article","sha256":"cd89907864dafe2225faa41cf01abddb2891e3a8efc60820db4b53b8cf5c0e9f","slug":"papers.neuromorphic-hw.index","location":"/papers/neuromorphic-hw/index.md","dependencies":[],"frontmatter":{"title":"Neuromorphic Hardware","description":"Neuromorphic chips and systems — Loihi, TrueNorth, SpiNNaker, Neurogrid, analog VLSI, and silicon neurons.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-8a51078b0f4e0dd19b8d3f44af69480b.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Scope","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"V2XWz0H8aB"}],"identifier":"scope","label":"Scope","html_id":"scope","implicit":true,"key":"M9f29NWiNz"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Neuromorphic hardware implements networks of spiking neuron and synapse circuits directly in silicon, with computation emerging from spike propagation through a reconfigurable connectivity fabric rather than sequential instruction execution. The architecture is explicitly modelled on biological neural circuits. The field originates in Carver Mead’s subthreshold analog VLSI work at Caltech in the late 1980s.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"jL0wKgirev"}],"key":"xQcxHA2PHJ"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Relevance","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"uRSJcmT9qH"}],"identifier":"relevance","label":"Relevance","html_id":"relevance","implicit":true,"key":"HUP7qlwWad"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"childre